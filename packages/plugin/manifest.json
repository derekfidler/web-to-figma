{
  "name": "Web to Figma",
  "id": "web-to-figma-dev",
  "api": "1.0.0",
  "main": "dist/code.js",
  "ui": "dist/ui.html",
  "editorType": ["figma"],
  "permissions": ["teamlibrary"],
  "networkAccess": {
    "allowedDomains": [
      "http://localhost:4321",
      "https://*.vercel.app",
      "https://*.flatpay.dev"
