{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "dist",
    "lib": ["ES2017", "DOM"],
    "types": ["@figma/plugin-typings"]
  },
  "include": ["src/**/*"]
}
